# Static web (nginx) behind Traefik. One container, multi-vhost via nginx.conf. Managed by Ansible.
# Content on host: /var/www/html/<doc_root>/public. Uses Cloudflare Origin Cert when enabled; else ACME.
services:
  nginx:
    image: nginx:alpine
    container_name: static-web
    restart: unless-stopped
    volumes:
      - /var/www/html:/var/www/html:ro
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
    labels:
      - traefik.enable=true
{% for vhost in static_web_vhosts %}
      - traefik.http.routers.static-web-{{ vhost.fqdn | replace('.', '-') }}.rule=Host(`{{ vhost.fqdn }}`)
      - traefik.http.routers.static-web-{{ vhost.fqdn | replace('.', '-') }}.entrypoints=websecure
      - traefik.http.routers.static-web-{{ vhost.fqdn | replace('.', '-') }}.tls=true
{% if not (cloudflare_origin_cert_enabled | default(false)) %}
      - traefik.http.routers.static-web-{{ vhost.fqdn | replace('.', '-') }}.tls.certresolver=cloudflare
{% endif %}
      - traefik.http.routers.static-web-{{ vhost.fqdn | replace('.', '-') }}.service=static-web-svc
{% endfor %}
      - traefik.http.services.static-web-svc.loadbalancer.server.port=80
      - traefik.docker.network=proxy
    networks:
      - proxy

networks:
  proxy:
    external: true
