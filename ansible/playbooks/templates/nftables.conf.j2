# Kaiju firewall — allow SSH, SMTP, HTTPS, IMAPS. Managed by Ansible.
# Docker bridge rules reference iif/oif "docker0"; nft rejects reload if that interface
# does not exist yet. They are included only when nftables_enable_docker_forward is true,
# or when ansible_facts show docker0 (e.g. harden re-run after Docker is installed).
{% set _wan = nftables_forward_interface | default((ansible_facts['default_ipv4'] | default({}))['interface'] | default('bond0')) %}
{% set _docker_fwd = (nftables_enable_docker_forward | bool) if (nftables_enable_docker_forward is defined) else ('docker0' in (ansible_facts['interfaces'] | default([]))) %}
flush ruleset

table inet filter {
  chain input {
    type filter hook input priority filter; policy drop;

    # Loopback
    iif "lo" accept
    # Established/related
    ct state established,related accept
    # Invalid drop
    ct state invalid drop

    # SSH
    tcp dport 22 accept
    # SMTP
    tcp dport 25 accept
    tcp dport 465 accept
    tcp dport 587 accept
    # HTTPS
    tcp dport 443 accept
    # IMAPS
    tcp dport 993 accept

    # ICMP (ping)
    ip protocol icmp accept
    ip6 nexthdr ipv6-icmp accept

    # Default drop
    drop
  }

  chain forward {
    type filter hook forward priority filter; policy drop;
    ct state established,related accept
{% if _docker_fwd %}
    # Host↔Docker bridge (requires docker0 to exist — see docker.yml after Docker install)
    iif "docker0" oifname "{{ _wan }}" accept
    iifname "{{ _wan }}" oif "docker0" ct state established,related accept
{% endif %}
    drop
  }

  chain output {
    type filter hook output priority filter; policy accept;
  }
}
