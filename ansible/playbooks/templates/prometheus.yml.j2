global:
  scrape_interval: {{ prometheus_scrape_interval }}

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["prometheus:9090"]

  - job_name: "node-exporter"
    static_configs:
      - targets: ["localhost:9100"]

  - job_name: "cadvisor"
    static_configs:
      - targets: ["cadvisor:8080"]

  - job_name: "traefik"
    static_configs:
      - targets: ["traefik:9100"]

{% if mailcow_exporter_enabled | default(false) %}
  - job_name: "mailcow"
    static_configs:
      - targets: ["{{ mailcow_exporter_target }}"]
{% endif %}

