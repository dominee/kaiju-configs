services:
  prometheus:
    image: prom/prometheus:v3.0.0
    container_name: prometheus
    restart: unless-stopped
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus_data:/prometheus
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time={{ prometheus_retention_time }}"
    networks:
      - proxy

  grafana:
    image: grafana/grafana:latest
    container_name: grafana
    restart: unless-stopped
    environment:
      - GF_SECURITY_ADMIN_USER={{ grafana_admin_user | default('dominee') }}
      - GF_SECURITY_ADMIN_PASSWORD={{ grafana_admin_password }}
    volumes:
      - grafana_data:/var/lib/grafana
    labels:
      - traefik.enable=true
      - traefik.http.routers.grafana.rule=Host(`{{ grafana_fqdn }}`)
      - traefik.http.routers.grafana.entrypoints=websecure
      - traefik.http.routers.grafana.tls=true
{% if not (cloudflare_origin_cert_enabled | default(false)) %}
      - traefik.http.routers.grafana.tls.certresolver=cloudflare
{% endif %}
{% if observability_basic_auth_enabled | default(true) | bool %}
      - traefik.http.routers.grafana.middlewares=observability-auth@docker
      # Docker Compose expands $VARS inside labels; bcrypt hashes contain '$' and must be escaped as '$$'.
      - traefik.http.middlewares.observability-auth.basicauth.users={{ (observability_basic_auth_users | default([])) | map('regex_replace', '\\s+', '') | map('regex_replace', '\\$', '$$') | join(',') }}
{% endif %}
      - traefik.http.services.grafana.loadbalancer.server.port=3000
      - traefik.docker.network=proxy
    networks:
      - proxy

  node-exporter:
    image: prom/node-exporter:latest
    container_name: node-exporter
    restart: unless-stopped
    command:
      - "--path.rootfs=/host"
      - "--web.listen-address=:9100"
    volumes:
      - /:/host:ro,rslave
    networks:
      - proxy

  cadvisor:
    # Pin version to avoid unexpected breakage; required for cgroup v2 hosts.
    image: gcr.io/cadvisor/cadvisor:v0.49.1
    container_name: cadvisor
    restart: unless-stopped
    privileged: true
    pid: host
    command:
      - "--housekeeping_interval=30s"
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /sys/fs/cgroup:/sys/fs/cgroup:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /dev/disk/:/dev/disk:ro
    networks:
      - proxy

  dozzle:
    image: amir20/dozzle:latest
    container_name: dozzle
    restart: unless-stopped
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    labels:
      - traefik.enable=true
      - traefik.http.routers.dozzle.rule=Host(`{{ dozzle_fqdn }}`)
      - traefik.http.routers.dozzle.entrypoints=websecure
      - traefik.http.routers.dozzle.tls=true
{% if not (cloudflare_origin_cert_enabled | default(false)) %}
      - traefik.http.routers.dozzle.tls.certresolver=cloudflare
{% endif %}
{% if observability_basic_auth_enabled | default(true) | bool %}
      - traefik.http.routers.dozzle.middlewares=observability-auth@docker
      # Docker Compose expands $VARS inside labels; bcrypt hashes contain '$' and must be escaped as '$$'.
      - traefik.http.middlewares.observability-auth.basicauth.users={{ (observability_basic_auth_users | default([])) | map('regex_replace', '\\s+', '') | map('regex_replace', '\\$', '$$') | join(',') }}
{% endif %}
      - traefik.http.services.dozzle.loadbalancer.server.port=8080
      - traefik.docker.network=proxy
    networks:
      - proxy

networks:
  proxy:
    external: true

volumes:
  prometheus_data:
  grafana_data:

