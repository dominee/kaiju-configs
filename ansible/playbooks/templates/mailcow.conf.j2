# mailcow.conf — generated by Ansible for Traefik reverse proxy
# See https://github.com/mailcow/mailcow-dockerized

MAILCOW_HOSTNAME={{ mailcow_fqdn }}

MAILCOW_PASS_SCHEME=BLF-CRYPT

DBNAME=mailcow
DBUSER=mailcow
DBPASS={{ mailcow_dbpass }}
DBROOT={{ mailcow_dbroot }}

REDISPASS={{ mailcow_redispass }}

# Reverse proxy: Traefik owns 80/443 on the host.
# Keep mailcow's nginx published only on localhost high ports as a safety net
# (Traefik reaches nginx-mailcow over the Docker network, not via these host ports).
HTTP_BIND={{ mailcow_http_bind | default('127.0.0.1') }}
HTTP_PORT={{ mailcow_http_port | default('18080') }}
HTTPS_BIND={{ mailcow_https_bind | default('127.0.0.1') }}
HTTPS_PORT={{ mailcow_https_port | default('18443') }}
HTTP_REDIRECT=n

SMTP_PORT=25
SMTPS_PORT=465
SUBMISSION_PORT=587
IMAP_PORT=143
IMAPS_PORT=993
POP_PORT=110
POPS_PORT=995
SIEVE_PORT=4190
DOVEADM_PORT=127.0.0.1:19991
SQL_PORT=127.0.0.1:13306
REDIS_PORT=127.0.0.1:7654

TZ={{ mailcow_tz | default('Europe/Prague') }}

COMPOSE_PROJECT_NAME=mailcow
# Use Docker Compose V2 plugin
DOCKER_COMPOSE_VERSION=v2

ADDITIONAL_SAN=
# Traefik handles HTTPS; disable mailcow's built-in ACME and autodiscover SAN
AUTODISCOVER_SAN=n
# SOGo web interface on webmail hostname (geoip restrict via Cloudflare WAF)
ADDITIONAL_SERVER_NAMES={{ mailcow_webmail_fqdn }}

SKIP_LETS_ENCRYPT=y

ENABLE_SSL_SNI=n
SKIP_IP_CHECK=n
SKIP_HTTP_VERIFICATION=n
SKIP_UNBOUND_HEALTHCHECK=n
SKIP_CLAMD={{ mailcow_skip_clamd | default('n') }}
SKIP_OLEFY=n
SKIP_SOGO=n
SKIP_FTS=n
FTS_HEAP=128
FTS_PROCS=1
ALLOW_ADMIN_EMAIL_LOGIN=n

USE_WATCHDOG=y
WATCHDOG_NOTIFY_BAN=n
WATCHDOG_NOTIFY_START=y
WATCHDOG_EXTERNAL_CHECKS=n
WATCHDOG_VERBOSE=n

LOG_LINES=9999

IPV4_NETWORK=172.22.1
IPV6_NETWORK=fd4d:6169:6c63:6f77::/64

MAILDIR_SUB=Maildir
SOGO_EXPIRE_SESSION=480
SOGO_URL_ENCRYPTION_KEY={{ mailcow_sogo_key }}

DOVECOT_MASTER_USER=
DOVECOT_MASTER_PASS=

WEBAUTHN_ONLY_TRUSTED_VENDORS=n
SPAMHAUS_DQS_KEY=

ENABLE_IPV6=false
DISABLE_NETFILTER_ISOLATION_RULE=n

ACL_ANYONE=disallow
MAILDIR_GC_TIME=7200
