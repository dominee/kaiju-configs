# Static web nginx config — generated by Ansible. One server block per FQDN.
# Document root for each vhost: /var/www/html/<doc_root>/public

events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;
    sendfile      on;
    keepalive_timeout 65;

{% for vhost in static_web_vhosts %}
    server {
        listen 80;
        server_name {{ vhost.fqdn }};
        root /var/www/html/{{ vhost.doc_root }}/public;
        index index.html index.htm;
        location / {
            try_files $uri $uri/ =404;
        }
    }
{% endfor %}
}
