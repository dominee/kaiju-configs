# Copy to all.yml and fill in real values. all.yml is gitignored.
# These variables are used by playbooks; never commit secrets.

# --- SSH / access ---
# ansible_user and key are in inventory; optional overrides:
# ansible_user: dominee
# ansible_ssh_private_key_file: ~/.ssh/id_ed25519

# --- Domain and TLS ---
# Domain: hell.sk. DNS managed by Cloudflare.
# Repository convention: all hosts/services are under the hell.sk domain.
# Host FQDN: kaiju.hell.sk (web), mail.hell.sk (mail).
domain: hell.sk
kaiju_fqdn: "kaiju.{{ domain }}"       # host FQDN (web services)
acme_email: "admin@{{ domain }}"       # Let's Encrypt / ACME contact (for mail)
mailcow_fqdn: "mail.{{ domain }}"      # mail server hostname
# Must match mailcow.conf COMPOSE_PROJECT_NAME (traefik_certdumper --restart-containers uses these names).
# mailcow_compose_project_name: mailcow
# traefik-certs-dumper: single domain for flat cert.pem in data/assets/ssl (defaults to mailcow_fqdn).
# mailcow_certdumper_domain: "mail.{{ domain }}"

# --- Host IPs and hostnames (single server, bond0 with two IPs) ---
# Web services (Traefik, static sites): kaiju.hell.sk → web_ip
# Mail services (Mailcow): mail.hell.sk → mail_ip
# Set Cloudflare A records: kaiju.hell.sk → web_ip, mail.hell.sk → mail_ip (and mail-related FQDNs).
web_ip: "10.101.10.73"
mail_ip: "10.101.10.74"
web_hostname: "kaiju.{{ domain }}"
mail_hostname: "mail.{{ domain }}"

# --- nftables (harden.yml / docker.yml) ---
# Interface name used in forward chain for Docker↔host traffic (default: default route or bond0).
# nftables_forward_interface: bond0
# Force Docker forward rules on/off (default: auto — true if ansible_facts show docker0).
# nftables_enable_docker_forward: false

# --- Cloudflare (scoped API Tokens — recommended) ---
# Create tokens at: Dashboard → Manage Account → API Tokens → Create Token.
# Use "Edit zone DNS" template or custom with minimal permissions; never commit token values.
#
# ACME (Traefik Let's Encrypt DNS-01): Cloudflare Zone *DNS* Edit (creates _acme-challenge TXT records).
# "Zone SSL and Certificates" is NOT a substitute — it does not grant DNS record writes for Let's Encrypt.
# You may use the same API token value as cloudflare_dns_api_token if that token already has Zone DNS Edit.
# If Traefik logs error 10000 / "failed to create TXT record", the token in CF_DNS_API_TOKEN lacks DNS Edit.
cloudflare_acme_dns_token: "your-cloudflare-acme-dns-token"
# DNS automation (dns-validate, dns-cloudflare, mail-dns-records): DNS Read+Edit + Zone Read on hell.sk.
cloudflare_dns_api_token: "your-cloudflare-dns-api-token"
#
# Legacy: single token for both (until you split scopes). If set, it fills in when the above are empty.
# cloudflare_api_token: "your-single-cloudflare-api-token"
# Web services behind Cloudflare shield use Cloudflare Origin Certificates.
# Set to true after placing origin.pem and origin-key.pem in /opt/traefik/certs/
#
# IMPORTANT: When creating the Origin cert in Cloudflare, do NOT include *.domain or mail-related
# hostnames (mail, webmail, autodiscover, autoconfig) if Traefik must also issue Let's Encrypt
# for those names — Traefik OSS uses one TLS store; a matching Origin cert blocks ACME for the same SNI.
cloudflare_origin_cert_enabled: false
# Cloudflare Origin Cert: place cert/key pairs in /opt/traefik/certs/ before deploying.
# Use /certs/... paths below — that is the path *inside* the Traefik container (compose bind-mount);
# preflight maps them to /opt/traefik/certs/... on the host. You may instead use full host paths.
# Origin Certs are per Cloudflare zone. Add one entry per zone (e.g. hell.sk AND goldendawns-clan.cz).
# If a static_web_vhosts FQDN is outside the primary domain, it needs its own cert pair here
# or must rely on ACME instead (set cloudflare_origin_cert_enabled: false and use certresolver).
# Default (single pair for primary domain):
# origin_cert_pairs:
#   - cert_file: /certs/origin.pem
#     key_file:  /certs/origin-key.pem
# Multi-zone example:
# origin_cert_pairs:
#   - cert_file: /certs/origin-hell-sk.pem
#     key_file:  /certs/origin-hell-sk-key.pem
#   - cert_file: /certs/origin-goldendawns-clan-cz.pem
#     key_file:  /certs/origin-goldendawns-clan-cz-key.pem

# --- Cloudflare DNS automation ---
# Used by dns-cloudflare.yml and mail-dns-records.yml. Token should have Zone.DNS edit permissions.
# Optional override (defaults to domain):
# cloudflare_zone_name: "hell.sk"
# Optional: proxy webmail through Cloudflare (HTTP only). Keep mail.hell.sk DNS-only.
cf_webmail_proxied: false
# Orange cloud for kaiju, metrics, logs, and static_web_vhosts A records. Set false if those names are DNS-only in Cloudflare.
# cf_web_a_proxied: false
#
# Production static sites (same idea as validate_mail_dns): dns-cloudflare / dns-validate will not create, update,
# or expect A records for these FQDNs unless dns_production_static_allow_changes=true.
# Default list is apex, www, from under domain, plus goldendawns-clan.cz hostnames — override if needed:
# dns_production_static_fqdns:
#   - "{{ domain }}"
#   - "www.{{ domain }}"
# dns_production_static_allow_changes: false

# --- Mailcow ---
mailcow_install_path: /vault/mailcow
# Optional: bits for openssl dhparam at data/assets/ssl/dhparams.pem (Dovecot ssl_dh). Default 2048; 4096 is slower.
# mailcow_dhparam_bits: 2048
# SOGo web interface hostname; geoip restriction can be applied via Cloudflare WAF.
mailcow_webmail_fqdn: "webmail.{{ domain }}"
# Optional: list of country codes allowed for webmail (e.g. ["SK", "CZ"]). Enforce via Cloudflare WAF or Traefik plugin.
# mailcow_webmail_geoip_allowed_countries: ["SK", "CZ"]
# mailcow generate_config.sh will prompt for some; or set here and pass:
# mailcow_admin_user: admin
# mailcow_admin_pass: "secure-password"
# mailcow_mailbox_secret: "random-secret-for-mailbox"
#
# mail-flow-lab.yml — SMTP 587 + IMAPS 993 loop against mail_ip (vault the password)
# mail_flow_lab_test_user: "dominee@{{ domain }}"
# mail_flow_lab_test_password: "use-ansible-vault"
# TLS verify: playbook defaults to insecure (Origin/snake-oil). For strict LE verification: mail_flow_lab_tls_insecure: false
# mail_flow_lab_tls_insecure: false

# --- Optional: Docker deploy user (default from inventory) ---
docker_deploy_user: "{{ ansible_user }}"

# --- Static web (nginx) ---
# Content path on host: /var/www/html/<doc_root>/public. Multiple FQDNs can share the same doc_root.
# Do not add mail.hell.sk here — it is served by Mailcow.
static_web_vhosts:
  - { fqdn: "www.hell.sk", doc_root: "hell.sk" }
  - { fqdn: "hell.sk", doc_root: "hell.sk" }
  - { fqdn: "from.hell.sk", doc_root: "from.hell.sk" }
  - { fqdn: "goldendawns-clan.cz", doc_root: "goldendawns-clan.cz" }
  - { fqdn: "www.goldendawns-clan.cz", doc_root: "goldendawns-clan.cz" }

# Default document root for the fallback single-vhost config (when static_web_vhosts is not set).
# static_web_default_doc_root: "{{ domain }}"

# --- Observability / monitoring ---
# Hostnames for observability UIs (served via Traefik).
dozzle_fqdn: "logs.{{ domain }}"
grafana_fqdn: "metrics.{{ domain }}"

# Protect observability UIs with Traefik Basic Auth (recommended).
# Provide htpasswd-formatted user(s), ideally stored with ansible-vault in group_vars/all.yml.
# Example (bcrypt):
# observability_basic_auth_enabled: true
# observability_basic_auth_users:
#   - "dominee:$2y$05$................................................."
observability_basic_auth_enabled: true
observability_basic_auth_users: []

# Grafana credentials (set password via ansible-vault in group_vars/all.yml).
grafana_admin_user: "dominee"
# grafana_admin_password: "set-this-in-vault"

# Optional: healthcheck settings
# healthcheck_validate_certs: false
# healthcheck_basic_auth_user: "dominee"
# healthcheck_basic_auth_password: "..."

# Prometheus scrape configuration basics.
prometheus_retention_time: "15d"
prometheus_scrape_interval: "15s"

# Optional: Mailcow Prometheus exporter.
# If you deploy a mailcow exporter container, set:
# mailcow_exporter_enabled: true
# mailcow_exporter_target: "mailcow-exporter:9125"

# --- Mail migration (IMAP) ---
# Mailbox migration from abyss.hell.sk to Mailcow using imapsync.
# Store passwords in group_vars/all.yml using ansible-vault (never commit secrets).
imapsync_source_host: "abyss.hell.sk"
imapsync_dest_host: "mail.{{ domain }}"
# imapsync_accounts:
#   - user: "dominee@hell.sk"
#     source_password: "SOURCE_PASS"
#     dest_password: "DEST_PASS"
#   - user: "djiabliq@hell.sk"
#     source_password: "SOURCE_PASS"
#     dest_password: "DEST_PASS"
#   - user: "celo@hell.sk"
#     source_password: "SOURCE_PASS"
#     dest_password: "DEST_PASS"

# --- Mail DNS records (defaults are safe for lab, but review for production) ---
# MX record for the apex domain points to mail.hell.sk by default.
mail_mx_priority: 10
# SPF default is strict; adjust if you send from other services.
mail_spf_value: "v=spf1 mx -all"
# DMARC default is monitor-only; switch to quarantine/reject after validation.
dmarc_policy: "none"   # none | quarantine | reject
dmarc_rua: "mailto:postmaster@{{ domain }}"
dmarc_ruf: "mailto:postmaster@{{ domain }}"
# DKIM: provide once you extract it from Mailcow (TXT record content).
# dkim_selector: "dkim"
# dkim_public_key: "v=DKIM1; k=rsa; p=MIIBIjANBgkqh..."
