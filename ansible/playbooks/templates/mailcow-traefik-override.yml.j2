# docker-compose.override.yml for mailcow behind Traefik v3
# Deployed by Ansible. See https://docs.mailcow.email/post_installation/reverse-proxy/r_p-traefik3/
# Hostnames: mail, autodiscover, autoconfig, webmail (SOGo). Restrict webmail by geoip via Cloudflare WAF.

services:
  certdumper:
    image: ghcr.io/kereis/traefik-certs-dumper:latest
    container_name: traefik_certdumper
    restart: unless-stopped
    network_mode: none
    command: --restart-containers mailcow_postfix-mailcow_1,mailcow_dovecot-mailcow_1
    volumes:
      - traefik_certs:/traefik:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./data/assets/ssl:/output:rw
    environment:
      - DOMAIN={{ domain }}
      - ACME_FILE_PATH=/traefik/acme.json

  nginx-mailcow:
    # Reverse proxy mode: nginx-mailcow listens on 8080 internally for HTTP.
    # Mailcow's default compose publishes 80/443 on the host; Traefik already owns 80/443.
    # Ports are controlled by mailcow.conf (HTTP_BIND/HTTP_PORT/HTTPS_BIND/HTTPS_PORT). Do not
    # override ports here to avoid compose merge surprises.
    labels:
      - traefik.enable=true
      - traefik.http.routers.mailcow-autodiscover.entrypoints=websecure
      - traefik.http.routers.mailcow-autodiscover.rule=Host(`autodiscover.{{ domain }}`) && Path(`/autodiscover/autodiscover.xml`)
      - traefik.http.routers.mailcow-autodiscover.tls=true
      - traefik.http.routers.mailcow-autodiscover.tls.certresolver=cloudflare
      - traefik.http.routers.mailcow-autodiscover.service=mailcow-svc
      - traefik.http.routers.mailcow-autoconfig.entrypoints=websecure
      - traefik.http.routers.mailcow-autoconfig.rule=Host(`autoconfig.{{ domain }}`) && Path(`/mail/config-v1.1.xml`)
      - traefik.http.routers.mailcow-autoconfig.tls=true
      - traefik.http.routers.mailcow-autoconfig.tls.certresolver=cloudflare
      - traefik.http.routers.mailcow-autoconfig.service=mailcow-svc
      - traefik.http.routers.mailcow.entrypoints=websecure
      - traefik.http.routers.mailcow.rule=Host(`{{ mailcow_fqdn }}`)
      - traefik.http.routers.mailcow.tls=true
      - traefik.http.routers.mailcow.tls.certresolver=cloudflare
      - traefik.http.routers.mailcow.service=mailcow-svc
      - traefik.http.routers.mailcow-webmail.entrypoints=websecure
      - traefik.http.routers.mailcow-webmail.rule=Host(`{{ mailcow_webmail_fqdn }}`)
      - traefik.http.routers.mailcow-webmail.tls=true
      - traefik.http.routers.mailcow-webmail.tls.certresolver=cloudflare
      - traefik.http.routers.mailcow-webmail.service=mailcow-svc
      # nginx-mailcow listens on HTTP_PORT inside the container; bind/publish is controlled by mailcow.conf
      - traefik.http.services.mailcow-svc.loadbalancer.server.port={{ mailcow_traefik_upstream_port | default(mailcow_http_port | default('18080')) }}
      - traefik.docker.network=proxy
    networks:
      - mailcow-network
      - proxy
    restart: always

networks:
  proxy:
    external: true

volumes:
  traefik_certs:
    external: true
