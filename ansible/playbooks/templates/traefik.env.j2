# Traefik → lego Cloudflare DNS-01: must create/delete TXT records (_acme-challenge.*).
# Requires Zone DNS Edit (API: DNS Write), NOT "Zone SSL and Certificates" alone — SSL permissions
# manage Cloudflare edge/origin settings, not DNS records for Let's Encrypt.
#
# Order: cloudflare_acme_dns_token, else cloudflare_dns_api_token (same secret in vault as both is OK),
# else legacy cloudflare_api_token.
CF_DNS_API_TOKEN={{ cloudflare_acme_dns_token | default(cloudflare_dns_api_token | default(cloudflare_api_token, true), true) }}
